<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="sale_order_approval_email_template" model="mail.template">
        <field name="name">Sale Order Approval Email</field>
        <field name="model_id" ref="sale.model_sale_order"/>
        <field name="email_from">{{ object.company_id.email or user.email }}</field>
        <field name="subject">Sale Order {{ object.name }} Requires Approval</field>
        <field name="body_html"><![CDATA[
<p>Dear Manager,</p>

<p>Sale Order <b>{{ object.name }}</b> requires your approval.</p>
<p>Customer: {{ object.partner_id.name }}</p>
<p>Amount: {{ object.currency_id.symbol }} {{ '%0.2f' % object.amount_total }}</p>

<p>
  Please take action by clicking one of the links below:
</p>

<p>
  ✅ <a href="{{ object.get_approval_url('approve') }}"><b>Approve</b></a>
  &nbsp;&nbsp;&nbsp;
  ❌ <a href="{{ object.get_approval_url('reject') }}"><b>Reject</b></a>
</p>

<p>Thank you!</p>
        ]]></field>
        <field name="auto_delete" eval="False"/>
    </record>
</odoo>