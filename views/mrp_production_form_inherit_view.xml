<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_mrp_production_form_inherit_no_warning" model="ir.ui.view">
            <field name="name">mrp.production.form.no.warning</field>
            <field name="model">mrp.production</field>
            <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
            <field name="arch" type="xml">

                <xpath expr="//header/button[@name='button_mark_done' and @invisible='move_raw_ids or not show_produce']" position="attributes">
                    <attribute name="confirm"></attribute>
                </xpath>

                <xpath expr="//header/button[@name='button_mark_done' and @invisible='move_raw_ids or not show_produce_all']" position="attributes">
                    <attribute name="confirm"></attribute>
                </xpath>

            </field>
        </record>
    </data>
</odoo>