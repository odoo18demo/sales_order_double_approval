<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_picking_form_inherit_delivery_info" model="ir.ui.view">
    <field name="name">stock.picking.form.delivery.info</field>
    <field name="model">stock.picking</field>
    <field name="inherit_id" ref="stock.view_picking_form"/>
    <field name="arch" type="xml">
        <xpath expr="//field[@name='location_id']" position="after">
                <field name="driver_name" required="1"/>
                <field name="driver_mobile" required="1"/>
                <field name="city_code"/>
        </xpath>
        <xpath expr="//field[@name='origin']" position="after">
                <field name="truck_plate_no" required="1"/>
                <field name="customer_phone"/>
                <field name="leave_time" widget="float_time"/>
        </xpath>
        <xpath expr="//header" position="inside">
            <button
                name="%(action_report_delivery_note_custom)d"
                type="action"
                string="Delivery Note"
                class="btn-primary"/>
        </xpath>
        <!-- Hide the Print button shown when state = done -->
<!--        <xpath expr="//header/button[@name='375' and @type='action']" position="attributes">-->
<!--            <attribute name="invisible">1</attribute>-->
<!--        </xpath>-->
<!--        <xpath expr="//header/button[@name='do_print_picking']" position="attributes">-->
<!--            <attribute name="invisible">1</attribute>-->
<!--        </xpath>-->
    </field>
</record>
</odoo>
