<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="mail_notification_layout_no_footer"
              inherit_id="mail.mail_notification_layout">

        <xpath expr="//t[@t-set='show_footer']" position="replace">
            <t t-set="show_footer" t-value="False"/>
        </xpath>

    </template>

</odoo>