<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="mrp_screen_template" name="MRP Manufacturing Screen">
        <html>
            <head>
                <meta charset="UTF-8"/>
                <meta http-equiv="refresh" content="30"/>
                <title>Manufacturing Orders</title>
                <link rel="stylesheet" href="/web/static/lib/bootstrap/css/bootstrap.css"/>
                <style>
                    body {
                        background: #f8f9fa;
                        padding: 24px;
                        font-family: 'Roboto', Arial, sans-serif;
                    }
                    .refresh-bar {
                        text-align: right;
                        font-size: 12px;
                        color: #6c757d;
                        margin-bottom: 16px;
                    }
                    .mo-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                        gap: 16px;
                    }
                    .mo-card {
                        background: #ffffff;
                        border-radius: 8px;
                        border: 1px solid #dee2e6;
                        overflow: hidden;
                    }
                    .mo-card-header {
                        padding: 12px 16px;
                        font-weight: 600;
                        font-size: 14px;
                        color: #ffffff;
                    }
                    .mo-card-header.confirmed { background: #042c53; }
                    .mo-card-header.progress  { background: #f0ad4e; color: #212529; }
                    .mo-card-header.to_close  { background: #28a745; }
                    .mo-card-body {
                        padding: 14px 16px;
                    }
                    .mo-product {
                        font-size: 15px;
                        font-weight: 600;
                        color: #212529;
                        margin-bottom: 8px;
                    }
                    .mo-meta {
                        font-size: 13px;
                        color: #6c757d;
                        margin-bottom: 4px;
                    }
                    .mo-meta span {
                        color: #212529;
                        font-weight: 500;
                    }
                    .mo-divider {
                        border: none;
                        border-top: 1px solid #dee2e6;
                        margin: 10px 0;
                    }
                    .mo-components-title {
                        font-size: 12px;
                        font-weight: 600;
                        color: #6c757d;
                        text-transform: uppercase;
                        letter-spacing: 0.5px;
                        margin-bottom: 6px;
                    }
                    .mo-component-item {
                        font-size: 13px;
                        color: #495057;
                        padding: 2px 0;
                        border-bottom: 1px solid #f1f3f5;
                    }
                    .status-pill {
                        display: inline-block;
                        padding: 2px 10px;
                        border-radius: 12px;
                        font-size: 11px;
                        font-weight: 600;
                    }
                    .status-pill.confirmed { background: #e0f5f5; color: #042c53; }
                    .status-pill.progress  { background: #fff3cd; color: #856404; }
                    .status-pill.to_close  { background: #d4edda; color: #155724; }
                    .empty-state {
                        text-align: center;
                        padding: 60px 20px;
                        color: #6c757d;
                        font-size: 15px;
                    }
                    .counter {
                        font-size: 12px;
                        color: #adb5bd;
                    }
                </style>
            </head>
            <body>

                <div class="refresh-bar">
                    Auto-refresh in <b id="countdown">30</b>s
                </div>

                <div class="mo-grid">

                    <t t-foreach="productions" t-as="mo">

                        <div class="mo-card">

                            <div t-attf-class="mo-card-header {{ mo.state }}">
                                <t t-out="mo.name"/>
                                — <t t-out="mo.product_id.name"/>
                            </div>

                            <div class="mo-card-body">

                                <div class="mo-meta">
                                    Qty:
                                    <span>
                                        <t t-out="mo.product_qty"/>
                                        <t t-out="mo.product_uom_id.name"/>
                                    </span>
                                </div>

                                <div class="mo-meta">
                                    Scheduled:
                                    <span t-out="mo.date_start or '—'"/>
                                </div>

                                <div class="mo-meta">
                                    Status:
                                    <span t-attf-class="status-pill {{ mo.state }}">
                                        <t t-if="mo.state == 'confirmed'">Confirmed</t>
                                        <t t-if="mo.state == 'progress'">In Progress</t>
                                        <t t-if="mo.state == 'to_close'">To Close</t>
                                    </span>
                                </div>

                                <t t-if="mo.move_raw_ids">
                                    <hr class="mo-divider"/>
                                    <div class="mo-components-title">Components</div>
                                    <t t-foreach="mo.move_raw_ids" t-as="line">
                                        <div class="mo-component-item">
                                            <t t-out="line.product_id.name"/>
                                            —
                                            <t t-out="line.product_uom_qty"/>
                                            <t t-out="line.product_uom.name"/>
                                        </div>
                                    </t>
                                </t>

                            </div>
                        </div>

                    </t>

                    <t t-if="not productions">
                        <div class="empty-state">
                            No active manufacturing orders found.
                        </div>
                    </t>

                </div>

                <script>
                    var sec = 10;
                    setInterval(function() {
                        sec--;
                        var el = document.getElementById('countdown');
                        if (el) el.innerText = sec;
                        if (sec &lt;= 0) window.location.reload();
                    }, 1000);
                </script>

            </body>
        </html>
    </template>
    <template id="maintenance_request_template" name="Maintenance Request Form">
        <html>
            <head>
                <meta charset="UTF-8"/>
                    <title>Maintenance Request</title>
                    <link rel="stylesheet" href="/web/static/lib/bootstrap/css/bootstrap.css"/>
                    <style>
                body {
                    background: #f8f9fa;
                    font-family: Arial, sans-serif;
                    display: flex;
                    align-items: flex-start;
                    justify-content: center;
                    min-height: 100vh;
                    margin: 0;
                    padding: 32px 16px;
                }
                .form-card {
                    background: #ffffff;
                    border-radius: 10px;
                    border: 1px solid #dee2e6;
                    padding: 32px;
                    width: 100%;
                    max-width: 560px;
                }
                .form-title {
                    font-size: 20px;
                    font-weight: 700;
                    color: #042c53;
                    margin-bottom: 4px;
                }
                .form-subtitle {
                    font-size: 13px;
                    color: #6c757d;
                    margin-bottom: 24px;
                }
                .form-label {
                    font-size: 13px;
                    font-weight: 600;
                    color: #495057;
                    margin-bottom: 4px;
                    display: block;
                }
                .form-control, .form-select {
                    font-size: 14px;
                    border: 1px solid #ced4da;
                    border-radius: 6px;
                    padding: 8px 12px;
                    width: 100%;
                    margin-bottom: 16px;
                    outline: none;
                    box-sizing: border-box;
                }
                .form-control:focus, .form-select:focus {
                    border-color: #042c53;
                    box-shadow: 0 0 0 2px rgba(4,44,83,0.15);
                }
                textarea.form-control {
                    resize: vertical;
                    min-height: 90px;
                }
                .btn-submit {
                    background: #042c53;
                    color: #ffffff;
                    border: none;
                    border-radius: 6px;
                    padding: 10px 28px;
                    font-size: 15px;
                    font-weight: 600;
                    cursor: pointer;
                    width: 100%;
                }
                .btn-submit:hover { background: #063a6e; }
                .btn-submit:disabled { background: #aaa; cursor: not-allowed; }
                .alert-success {
                    background: #d4edda;
                    color: #155724;
                    border: 1px solid #c3e6cb;
                    border-radius: 6px;
                    padding: 12px 16px;
                    margin-bottom: 20px;
                    font-size: 14px;
                }
                .alert-error {
                    background: #f8d7da;
                    color: #721c24;
                    border: 1px solid #f5c6cb;
                    border-radius: 6px;
                    padding: 12px 16px;
                    margin-bottom: 20px;
                    font-size: 14px;
                }
                .priority-group {
                    display: flex;
                    gap: 8px;
                    margin-bottom: 16px;
                }
                .priority-label {
                    flex: 1;
                    display: block;
                    text-align: center;
                }
                .priority-btn {
                    width: 100%;
                    padding: 7px 4px;
                    border: 1px solid #ced4da;
                    border-radius: 6px;
                    background: #fff;
                    font-size: 12px;
                    cursor: pointer;
                    transition: all 0.15s;
                }
                .priority-btn:hover { border-color: #042c53; color: #042c53; }
                .priority-btn.active {
                    background: #042c53;
                    color: white;
                    border-color: #042c53;
                }
                .photo-upload-area {
                    border: 2px dashed #ced4da;
                    border-radius: 8px;
                    padding: 20px;
                    text-align: center;
                    cursor: pointer;
                    margin-bottom: 12px;
                    background: #fafafa;
                    transition: border-color 0.2s;
                }
                .photo-upload-area:hover { border-color: #042c53; }
                .photo-upload-area.dragover {
                    border-color: #042c53;
                    background: #e8eef5;
                }
                .upload-icon { font-size: 32px; margin-bottom: 8px; }
                .upload-text { font-size: 13px; color: #6c757d; }
                .upload-text strong { color: #042c53; }
                .photo-actions {
                    display: flex;
                    gap: 8px;
                    margin-bottom: 16px;
                }
                .btn-photo {
                    flex: 1;
                    padding: 8px;
                    border: 1px solid #042c53;
                    border-radius: 6px;
                    background: #fff;
                    color: #042c53;
                    font-size: 13px;
                    font-weight: 600;
                    cursor: pointer;
                }
                .btn-photo:hover { background: #e8eef5; }
                .photo-preview-grid {
                    display: grid;
                    grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
                    gap: 8px;
                    margin-bottom: 16px;
                }
                .photo-preview-item {
                    position: relative;
                    border-radius: 6px;
                    overflow: hidden;
                    border: 1px solid #dee2e6;
                    aspect-ratio: 1;
                }
                .photo-preview-item img {
                    width: 100%;
                    height: 100%;
                    object-fit: cover;
                    display: block;
                }
                .photo-remove {
                    position: absolute;
                    top: 3px;
                    right: 3px;
                    background: rgba(0,0,0,0.6);
                    color: white;
                    border: none;
                    border-radius: 50%;
                    width: 20px;
                    height: 20px;
                    font-size: 12px;
                    cursor: pointer;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                }
                .photo-count {
                    font-size: 12px;
                    color: #6c757d;
                    margin-bottom: 16px;
                }
                .new-request-btn {
                    background: none;
                    border: 1px solid #042c53;
                    color: #042c53;
                    border-radius: 6px;
                    padding: 8px 20px;
                    font-size: 14px;
                    cursor: pointer;
                    width: 100%;
                    margin-top: 8px;
                }
                .camera-modal {
                    display: none;
                    position: fixed;
                    top: 0; left: 0;
                    width: 100%; height: 100%;
                    background: rgba(0,0,0,0.85);
                    z-index: 9999;
                    flex-direction: column;
                    align-items: center;
                    justify-content: center;
                }
                .camera-modal.open { display: flex; }
                #camera-video {
                    width: 100%;
                    max-width: 420px;
                    border-radius: 8px;
                    background: #000;
                }
                .camera-controls {
                    display: flex;
                    gap: 12px;
                    margin-top: 16px;
                }
                .btn-capture {
                    background: #042c53;
                    color: white;
                    border: none;
                    border-radius: 50%;
                    width: 60px;
                    height: 60px;
                    font-size: 24px;
                    cursor: pointer;
                }
                .btn-close-camera {
                    background: #dc3545;
                    color: white;
                    border: none;
                    border-radius: 50%;
                    width: 44px;
                    height: 44px;
                    font-size: 18px;
                    cursor: pointer;
                }
            </style>
            </head>
            <body>
                <div class="camera-modal" id="cameraModal">
                    <video id="camera-video" autoplay="1" playsinline="1"></video>
                    <canvas id="camera-canvas" style="display:none;"></canvas>
                    <div class="camera-controls">
                        <button class="btn-close-camera" id="closeCamera">&#10005;</button>
                        <button class="btn-capture" id="captureBtn">&#128247;</button>
                    </div>
                    <p style="color:#aaa; font-size:12px; margin-top:10px;">
                        Tap &#128247; to capture — you can take multiple photos
                    </p>
                </div>

                <div class="form-card">

                    <div class="form-title">&#128295; Maintenance Request</div>
                    <div class="form-subtitle">
                        Report an issue or schedule a maintenance task.
                    </div>

                    <t t-if="success">
                        <div class="alert-success">
                            &#10003; Maintenance request submitted successfully!
                            <t t-if="photo_count and photo_count > 0">
                                <br/><b><t t-out="photo_count"/></b> photo(s) attached.
                            </t>
                            <t t-if="not photo_count or photo_count == 0">
                                <br/>No photos were attached.
                            </t>
                        </div>
                        <a href="/maintenance-request">
                            <button class="new-request-btn">Submit Another Request</button>
                        </a>
                    </t>

                    <t t-if="error">
                        <div class="alert-error">&#9888; <t t-out="error"/></div>
                    </t>

                    <t t-if="not success">
                        <form id="maintenanceForm"
                              action="/maintenance-request/submit"
                              method="POST"
                              enctype="multipart/form-data">

                            <label class="form-label">Request Name *</label>
                            <input type="text" name="name" class="form-control"
                                   placeholder="e.g. Machine not starting"
                                   t-att-value="values.get('name', '') if values else ''"/>

                            <label class="form-label">Equipment</label>
                            <select name="equipment_id" class="form-select">
                                <option value="">— Select Equipment (optional) —</option>
                                <t t-foreach="equipments" t-as="eq">
                                    <option t-att-value="eq.id" t-out="eq.name"/>
                                </t>
                            </select>

                            <label class="form-label">Maintenance Type</label>
                            <select name="maintenance_type" class="form-select">
                                <option value="corrective">Corrective (Fix a problem)</option>
                                <option value="preventive">Preventive (Scheduled check)</option>
                            </select>

                            <label class="form-label">Priority</label>
                            <div class="priority-group">
                                <label class="priority-label">
                                    <button type="button" class="priority-btn active" data-value="0">Normal</button>
                                </label>
                                <label class="priority-label">
                                    <button type="button" class="priority-btn" data-value="1">Urgent</button>
                                </label>
                                <label class="priority-label">
                                    <button type="button" class="priority-btn" data-value="2">Very Urgent</button>
                                </label>
                                <label class="priority-label">
                                    <button type="button" class="priority-btn" data-value="3">Critical</button>
                                </label>
                            </div>
                            <input type="hidden" name="priority" id="priorityInput" value="0"/>

                            <label class="form-label">Description</label>
                            <textarea name="description" class="form-control"
                                      placeholder="Describe the issue in detail..."><t t-out="values.get('description', '') if values else ''"/></textarea>

                            <!-- Photo Upload Section -->
                            <label class="form-label">Machine Photos</label>
                            <div class="photo-actions">
                                <button type="button" class="btn-photo" id="openCamera">
                                    &#128247; Take Photo
                                </button>
                                <button type="button" class="btn-photo"
                                        onclick="document.getElementById('fileInput').click()">
                                    &#128193; Choose Files
                                </button>
                            </div>

                            <!-- Regular file input — still useful for direct pick -->
                            <input type="file" id="fileInput" accept="image/*"
                                   multiple="1" style="display:none;"/>

                            <!-- Base64 hidden inputs will be injected here by JS -->
                            <div id="hiddenInputs"></div>

                            <div class="photo-upload-area" id="dropZone">
                                <div class="upload-icon">&#128444;</div>
                                <div class="upload-text">
                                    <strong>Drag and drop</strong> photos here<br/>
                                    or use the buttons above
                                </div>
                            </div>

                            <div class="photo-count" id="photoCount" style="display:none;">
                                <span id="countText">0</span> photo(s) selected
                            </div>
                            <div class="photo-preview-grid" id="previewGrid"></div>

                            <button type="submit" class="btn-submit" id="submitBtn">
                                Submit Request
                            </button>

                        </form>
                    </t>
                </div>
                <script>
                //<![CDATA[
                (function() {
                    var allFiles = [];
                    var cameraStream = null;

                    // Priority buttons
                    document.querySelectorAll('.priority-btn').forEach(function(btn) {
                        btn.addEventListener('click', function() {
                            document.querySelectorAll('.priority-btn').forEach(function(b) {
                                b.classList.remove('active');
                            });
                            btn.classList.add('active');
                            document.getElementById('priorityInput').value = btn.dataset.value;
                        });
                    });

                    // File input
                    document.getElementById('fileInput').addEventListener('change', function() {
                        addFiles(Array.from(this.files));
                        this.value = '';
                    });

                    // Drag and drop
                    var dropZone = document.getElementById('dropZone');
                    dropZone.addEventListener('dragover', function(e) {
                        e.preventDefault();
                        dropZone.classList.add('dragover');
                    });
                    dropZone.addEventListener('dragleave', function() {
                        dropZone.classList.remove('dragover');
                    });
                    dropZone.addEventListener('drop', function(e) {
                        e.preventDefault();
                        dropZone.classList.remove('dragover');
                        var files = Array.from(e.dataTransfer.files).filter(function(f) {
                            return f.type.startsWith('image/');
                        });
                        addFiles(files);
                    });
                    dropZone.addEventListener('click', function() {
                        document.getElementById('fileInput').click();
                    });

                    // Camera open
                    document.getElementById('openCamera').addEventListener('click', function() {
                        var modal = document.getElementById('cameraModal');
                        modal.classList.add('open');
                        navigator.mediaDevices.getUserMedia({
                            video: { facingMode: 'environment' }
                        }).then(function(stream) {
                            cameraStream = stream;
                            document.getElementById('camera-video').srcObject = stream;
                        }).catch(function() {
                            alert('Camera not accessible. Please use Choose Files instead.');
                            modal.classList.remove('open');
                        });
                    });

                    // Camera close
                    document.getElementById('closeCamera').addEventListener('click', function() {
                        stopCamera();
                    });

                    // Capture photo from camera
                    document.getElementById('captureBtn').addEventListener('click', function() {
                        var video = document.getElementById('camera-video');
                        var canvas = document.getElementById('camera-canvas');
                        canvas.width = video.videoWidth;
                        canvas.height = video.videoHeight;
                        canvas.getContext('2d').drawImage(video, 0, 0);
                        canvas.toBlob(function(blob) {
                            var file = new File([blob], 'camera_' + Date.now() + '.jpg', {
                                type: 'image/jpeg'
                            });
                            addFiles([file]);
                        }, 'image/jpeg', 0.85);
                    });

                    function stopCamera() {
                        if (cameraStream) {
                            cameraStream.getTracks().forEach(function(t) { t.stop(); });
                            cameraStream = null;
                        }
                        document.getElementById('cameraModal').classList.remove('open');
                    }

                    // Add files — convert each to base64 and add hidden input
                    function addFiles(newFiles) {
                        newFiles.forEach(function(file) {
                            var index = allFiles.length;
                            allFiles.push(file);
                            convertToBase64(file, index);
                            addPreview(file, index);
                        });
                        updateCount();
                    }

                    // ✅ KEY FIX: Convert file to base64 and inject as hidden input
                    function convertToBase64(file, index) {
                        var reader = new FileReader();
                        reader.onload = function(e) {
                            var container = document.getElementById('hiddenInputs');

                            // data input
                            var dataInput = document.createElement('input');
                            dataInput.type = 'hidden';
                            dataInput.name = 'photo_data_' + index;
                            dataInput.id = 'photo_data_' + index;
                            dataInput.value = e.target.result;
                            container.appendChild(dataInput);

                            // name input
                            var nameInput = document.createElement('input');
                            nameInput.type = 'hidden';
                            nameInput.name = 'photo_name_' + index;
                            nameInput.value = file.name || ('photo_' + index + '.jpg');
                            container.appendChild(nameInput);
                        };
                        reader.readAsDataURL(file);
                    }

                    function addPreview(file, index) {
                        var reader = new FileReader();
                        reader.onload = function(e) {
                            var grid = document.getElementById('previewGrid');
                            var item = document.createElement('div');
                            item.className = 'photo-preview-item';
                            item.id = 'preview_' + index;
                            item.innerHTML =
                                '<img src="' + e.target.result + '" alt="photo"/>' +
                                '<button type="button" class="photo-remove" ' +
                                'onclick="removePhoto(' + index + ')">&#10005;</button>';
                            grid.appendChild(item);
                        };
                        reader.readAsDataURL(file);
                    }

                    window.removePhoto = function(index) {
                        allFiles[index] = null;

                        // Remove preview
                        var preview = document.getElementById('preview_' + index);
                        if (preview) preview.remove();

                        // Remove hidden inputs
                        var dataInput = document.getElementById('photo_data_' + index);
                        if (dataInput) dataInput.remove();

                        updateCount();
                    };

                    function updateCount() {
                        var active = allFiles.filter(function(f) { return f !== null; });
                        var countEl = document.getElementById('photoCount');
                        if (active.length > 0) {
                            countEl.style.display = 'block';
                            document.getElementById('countText').innerText = active.length;
                        } else {
                            countEl.style.display = 'none';
                        }
                    }

                })();
                //]]>
                </script>
            </body>
        </html>
    </template>
</odoo>