<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <template id="mrp_screen_template" name="MRP Manufacturing Screen">
        <html>
            <head>
                <meta charset="UTF-8"/>
                <meta http-equiv="refresh" content="30"/>
                <title>Manufacturing Orders</title>
                <link rel="stylesheet" href="/web/static/lib/bootstrap/css/bootstrap.css"/>
                <style>
                    body {
                        background: #f8f9fa;
                        padding: 24px;
                        font-family: 'Roboto', Arial, sans-serif;
                    }
                    .refresh-bar {
                        text-align: right;
                        font-size: 12px;
                        color: #6c757d;
                        margin-bottom: 16px;
                    }
                    .mo-grid {
                        display: grid;
                        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
                        gap: 16px;
                    }
                    .mo-card {
                        background: #ffffff;
                        border-radius: 8px;
                        border: 1px solid #dee2e6;
                        overflow: hidden;
                    }
                    .mo-card-header {
                        padding: 12px 16px;
                        font-weight: 600;
                        font-size: 14px;
                        color: #ffffff;
                    }
                    .mo-card-header.confirmed { background: #042c53; }
                    .mo-card-header.progress  { background: #f0ad4e; color: #212529; }
                    .mo-card-header.to_close  { background: #28a745; }
                    .mo-card-body {
                        padding: 14px 16px;
                    }
                    .mo-product {
                        font-size: 15px;
                        font-weight: 600;
                        color: #212529;
                        margin-bottom: 8px;
                    }
                    .mo-meta {
                        font-size: 13px;
                        color: #6c757d;
                        margin-bottom: 4px;
                    }
                    .mo-meta span {
                        color: #212529;
                        font-weight: 500;
                    }
                    .mo-divider {
                        border: none;
                        border-top: 1px solid #dee2e6;
                        margin: 10px 0;
                    }
                    .mo-components-title {
                        font-size: 12px;
                        font-weight: 600;
                        color: #6c757d;
                        text-transform: uppercase;
                        letter-spacing: 0.5px;
                        margin-bottom: 6px;
                    }
                    .mo-component-item {
                        font-size: 13px;
                        color: #495057;
                        padding: 2px 0;
                        border-bottom: 1px solid #f1f3f5;
                    }
                    .status-pill {
                        display: inline-block;
                        padding: 2px 10px;
                        border-radius: 12px;
                        font-size: 11px;
                        font-weight: 600;
                    }
                    .status-pill.confirmed { background: #e0f5f5; color: #042c53; }
                    .status-pill.progress  { background: #fff3cd; color: #856404; }
                    .status-pill.to_close  { background: #d4edda; color: #155724; }
                    .empty-state {
                        text-align: center;
                        padding: 60px 20px;
                        color: #6c757d;
                        font-size: 15px;
                    }
                    .counter {
                        font-size: 12px;
                        color: #adb5bd;
                    }
                </style>
            </head>
            <body>

                <div class="refresh-bar">
                    Auto-refresh in <b id="countdown">30</b>s
                </div>

                <div class="mo-grid">

                    <t t-foreach="productions" t-as="mo">

                        <div class="mo-card">

                            <div t-attf-class="mo-card-header {{ mo.state }}">
                                <t t-out="mo.name"/>
                                — <t t-out="mo.product_id.name"/>
                            </div>

                            <div class="mo-card-body">

                                <div class="mo-meta">
                                    Qty:
                                    <span>
                                        <t t-out="mo.product_qty"/>
                                        <t t-out="mo.product_uom_id.name"/>
                                    </span>
                                </div>

                                <div class="mo-meta">
                                    Scheduled:
                                    <span t-out="mo.date_start or '—'"/>
                                </div>

                                <div class="mo-meta">
                                    Status:
                                    <span t-attf-class="status-pill {{ mo.state }}">
                                        <t t-if="mo.state == 'confirmed'">Confirmed</t>
                                        <t t-if="mo.state == 'progress'">In Progress</t>
                                        <t t-if="mo.state == 'to_close'">To Close</t>
                                    </span>
                                </div>

                                <t t-if="mo.move_raw_ids">
                                    <hr class="mo-divider"/>
                                    <div class="mo-components-title">Components</div>
                                    <t t-foreach="mo.move_raw_ids" t-as="line">
                                        <div class="mo-component-item">
                                            <t t-out="line.product_id.name"/>
                                            —
                                            <t t-out="line.product_uom_qty"/>
                                            <t t-out="line.product_uom.name"/>
                                        </div>
                                    </t>
                                </t>

                            </div>
                        </div>

                    </t>

                    <t t-if="not productions">
                        <div class="empty-state">
                            No active manufacturing orders found.
                        </div>
                    </t>

                </div>

                <script>
                    var sec = 10;
                    setInterval(function() {
                        sec--;
                        var el = document.getElementById('countdown');
                        if (el) el.innerText = sec;
                        if (sec &lt;= 0) window.location.reload();
                    }, 1000);
                </script>

            </body>
        </html>
    </template>
    <template id="maintenance_request_template" name="Maintenance Request Form">
        <html>
            <head>
                <meta charset="UTF-8"/>
                <title>Maintenance Request</title>
                <link rel="stylesheet" href="/web/static/lib/bootstrap/css/bootstrap.css"/>
                <style>
                    body {
                        background: #f8f9fa;
                        font-family: Arial, sans-serif;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        min-height: 100vh;
                        margin: 0;
                        padding: 24px;
                    }
                    .form-card {
                        background: #ffffff;
                        border-radius: 10px;
                        border: 1px solid #dee2e6;
                        padding: 32px;
                        width: 100%;
                        max-width: 520px;
                    }
                    .form-title {
                        font-size: 20px;
                        font-weight: 700;
                        color: #042c53;
                        margin-bottom: 6px;
                    }
                    .form-subtitle {
                        font-size: 13px;
                        color: #6c757d;
                        margin-bottom: 24px;
                    }
                    .form-label {
                        font-size: 13px;
                        font-weight: 600;
                        color: #495057;
                        margin-bottom: 4px;
                    }
                    .form-control, .form-select {
                        font-size: 14px;
                        border: 1px solid #ced4da;
                        border-radius: 6px;
                        padding: 8px 12px;
                        width: 100%;
                        margin-bottom: 16px;
                        outline: none;
                        box-sizing: border-box;
                    }
                    .form-control:focus, .form-select:focus {
                        border-color: #042c53;
                        box-shadow: 0 0 0 2px rgba(1,126,132,0.15);
                    }
                    textarea.form-control { resize: vertical; min-height: 90px; }
                    .btn-submit {
                        background: #042c53;
                        color: #ffffff;
                        border: none;
                        border-radius: 6px;
                        padding: 10px 28px;
                        font-size: 15px;
                        font-weight: 600;
                        cursor: pointer;
                        width: 100%;
                    }
                    .btn-submit:hover { background: #015f63; }
                    .alert-success {
                        background: #d4edda;
                        color: #155724;
                        border: 1px solid #c3e6cb;
                        border-radius: 6px;
                        padding: 12px 16px;
                        margin-bottom: 20px;
                        font-size: 14px;
                    }
                    .alert-error {
                        background: #f8d7da;
                        color: #721c24;
                        border: 1px solid #f5c6cb;
                        border-radius: 6px;
                        padding: 12px 16px;
                        margin-bottom: 20px;
                        font-size: 14px;
                    }
                    .priority-group {
                        display: flex;
                        gap: 8px;
                        margin-bottom: 16px;
                    }
                    .priority-btn {
                        flex: 1;
                        padding: 7px;
                        border: 1px solid #ced4da;
                        border-radius: 6px;
                        background: #fff;
                        font-size: 13px;
                        cursor: pointer;
                        text-align: center;
                    }
                    .priority-btn:hover { border-color: #042c53; color: #042c53; }
                    input[type=radio]:checked + .priority-btn {
                        background: #042c53;
                        color: white;
                        border-color: #042c53;
                    }
                    .new-request-btn {
                        background: none;
                        border: 1px solid #042c53;
                        color: #042c53;
                        border-radius: 6px;
                        padding: 8px 20px;
                        font-size: 14px;
                        cursor: pointer;
                        width: 100%;
                        margin-top: 8px;
                    }
                </style>
            </head>
            <body>
                <div class="form-card">

                    <div class="form-title">&#128295; Maintenance Request</div>
                    <div class="form-subtitle">Report an issue or schedule a maintenance task.</div>

                    <!-- Success Message -->
                    <t t-if="success">
                        <div class="alert-success">
                            &#10003; Your maintenance request has been submitted successfully!
                        </div>
                        <a href="/maintenance-request">
                            <button class="new-request-btn">Submit Another Request</button>
                        </a>
                    </t>

                    <!-- Error Message -->
                    <t t-if="error">
                        <div class="alert-error">
                            &#9888; <t t-out="error"/>
                        </div>
                    </t>

                    <!-- Form -->
                    <t t-if="not success">
                        <form action="/maintenance-request/submit" method="POST">

                            <div class="form-label">Request Name *</div>
                            <input type="text" name="name" class="form-control"
                                   placeholder="e.g. Machine not starting"
                                   t-att-value="values.get('name', '') if values else ''"/>

                            <div class="form-label">Equipment</div>
                            <select name="equipment_id" class="form-select">
                                <option value="">— Select Equipment (optional) —</option>
                                <t t-foreach="equipments" t-as="eq">
                                    <option t-att-value="eq.id"
                                            t-out="eq.name"/>
                                </t>
                            </select>

                            <div class="form-label">Maintenance Type</div>
                            <select name="maintenance_type" class="form-select">
                                <option value="corrective">Corrective (Fix a problem)</option>
                                <option value="preventive">Preventive (Scheduled check)</option>
                            </select>

                            <div class="form-label">Priority</div>
                            <div class="priority-group">
                                <label style="flex:1; display:block; text-align:center;">
                                    <input type="radio" name="priority" value="0"
                                           style="display:none;" checked="1"/>
                                    <div class="priority-btn">Normal</div>
                                </label>
                                <label style="flex:1; display:block; text-align:center;">
                                    <input type="radio" name="priority" value="1"
                                           style="display:none;"/>
                                    <div class="priority-btn">Urgent</div>
                                </label>
                                <label style="flex:1; display:block; text-align:center;">
                                    <input type="radio" name="priority" value="2"
                                           style="display:none;"/>
                                    <div class="priority-btn">Very Urgent</div>
                                </label>
                                <label style="flex:1; display:block; text-align:center;">
                                    <input type="radio" name="priority" value="3"
                                           style="display:none;"/>
                                    <div class="priority-btn">Critical</div>
                                </label>
                            </div>

                            <div class="form-label">Description</div>
                            <textarea name="description" class="form-control"
                                      placeholder="Describe the issue in detail..."><t t-out="values.get('description', '') if values else ''"/></textarea>

                            <button type="submit" class="btn-submit">Submit Request</button>

                        </form>
                    </t>

                </div>

                <script>
                    // Priority button highlight on click
                    document.querySelectorAll('input[name="priority"]').forEach(function(radio) {
                        radio.addEventListener('change', function() {
                            document.querySelectorAll('.priority-btn').forEach(function(btn) {
                                btn.style.background = '';
                                btn.style.color = '';
                                btn.style.borderColor = '';
                            });
                            var btn = this.nextElementSibling;
                            btn.style.background = '#042c53';
                            btn.style.color = 'white';
                            btn.style.borderColor = '#042c53';
                        });
                    });
                </script>

            </body>
        </html>
    </template>
</odoo>